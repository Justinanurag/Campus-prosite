{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/campus/static/(.*)", "destination": "/static/$1" },
    { "source": "/campus", "destination": "/index.html" },
    { "source": "/campus/(.*)", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/", "destination": "/campus", "permanent": false }
  ]
}
